{
  "name": "quorumscope",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "demo": "node --import tsx src/cli/demo.ts",
    "bench": "node --import tsx src/cli/bench.ts",
    "search": "node --import tsx src/cli/search.ts",
    "search:first-ack": "node --import tsx src/cli/search.ts --protocol unsafe",
    "search:compare": "node --import tsx src/cli/search.ts --protocol compare"
  },
  "dependencies": {
    "lucide-react": "1.14.0",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vite": "8.0.10",
    "vitest": "4.1.5"
  }
}
